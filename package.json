{
  "name": "factorio-mod-tool",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "fmod": "out/cli.js"
  },
  "scripts": {
    "build": "npx shadow-cljs compile server cli http-server",
    "build:cli": "npx shadow-cljs compile cli",
    "build:server": "npx shadow-cljs compile server",
    "build:http": "npx shadow-cljs compile http-server",
    "build:test": "npx shadow-cljs compile test",
    "watch": "npx shadow-cljs watch server",
    "watch:cli": "npx shadow-cljs watch cli",
    "watch:test": "npx shadow-cljs watch test",
    "start": "node out/server.js",
    "serve": "node out/http-server.js",
    "fmod": "node out/cli.js",
    "repl": "npx shadow-cljs node-repl"
  },
  "dependencies": {
    "luaparse": "^0.3.1",
    "rcon-client": "^4.2.4",
    "archiver": "^7.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "shadow-cljs": "^3.1.7"
  }
}
